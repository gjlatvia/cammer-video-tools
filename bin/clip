#!/usr/bin/env bash

# clip myvideo.mp4 0:01:23 0:02:34
#   → creates myvideo_0-01-23_0-02-34.mp4
# clip myvideo.mp4 5:00 5:30 clip.mp4
#   → creates clip.mp4 (from 5:00 to 5:30)
#
# start_time and end_time can be written as HH:MM:SS or MM:SS.
# Output defaults to a filename based on the input + times.

if [ $# -lt 3 ]; then
    echo "Usage: clip inputfile start_time end_time [outputfile]"
    echo "Example: clip video.mp4 0:01:23 0:02:34"
    return 1
fi

infile="$1"
start="$2"
end="$3"
if [ $# -ge 4 ]; then
    outfile="$4"
else
    # default output: input name + start-end
    base="${infile%.*}"
    ext="${infile##*.}"
    outfile="${base}_${start//:/-}_${end//:/-}.${ext}"
fi

ffmpeg -i "$infile" -ss "$start" -to "$end" -c copy "$outfile"
